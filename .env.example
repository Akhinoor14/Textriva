# Vercel Blob storage token
# 1. Vercel Dashboard → Storage → Blob → Create Store
# 2. Copy the BLOB_READ_WRITE_TOKEN and paste below
BLOB_READ_WRITE_TOKEN=vercel_blob_rw_xxxxxxxxxxxxxxxx

# ISP Block workaround:
# If your Vercel *.vercel.app domain is blocked by your ISP,
# add a custom domain in Vercel Dashboard → Settings → Domains
# Free option: get a subdomain at https://is-a.dev or use Cloudflare Pages
